# LUL Terminal — copy to .env and adjust for your environment
# cp .env.example .env   (Linux/macOS)
# copy .env.example .env (Windows)

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Required in production behind nginx, Caddy, Cloudflare, Vercel, etc.
# Enables real client IPs for rate limits (see Admin → Setup Notes).
TRUST_PROXY=0

# ── First-run auth (empty data/auth/users.json only) ─────────────────────────
# Required in production when seeding the default admin + VIP demo accounts.
SEED_ADMIN_PASSWORD=change-me-admin
SEED_VIP_PASSWORD=change-me-vip

# ── Premium vault encryption (production required) ─────────────────────────────
PREMIUM_VAULT_KEY=change-me-long-random-secret

# ── Optional dev ─────────────────────────────────────────────────────────────
# DISABLE_HMR=true

# ── Optional AI Studio / Gemini (meme tools) ─────────────────────────────────
# GEMINI_API_KEY=
# APP_URL=http://localhost:3000