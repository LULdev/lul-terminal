# LUL Terminal — copy to .env and adjust for your environment
# cp .env.example .env   (Linux/macOS)
# copy .env.example .env (Windows)
# Ubuntu one-click dev: scripts/install-ubuntu-dev.sh (creates .env automatically)

# ── Server ────────────────────────────────────────────────────────────────────
# Docker: docker compose up -d --build  (see README → Docker-Anleitung)
PORT=3000
NODE_ENV=development

# Required in production behind nginx, Caddy, Cloudflare, Vercel, etc.
# Enables real client IPs for rate limits (see Admin → Setup Notes).
TRUST_PROXY=0
# Comma-separated proxy hop IPs allowed to set X-Forwarded-For / X-Real-IP / X-Forwarded-Host / X-Forwarded-Proto (default: loopback).
# TRUSTED_PROXY_IPS=127.0.0.1,::1,::ffff:127.0.0.1

# Optional: canonical public origin for paste/image/referral URLs in API responses (overrides Host header).
# PUBLIC_BASE_URL=https://terminal.example.com
#
# When TRUST_PROXY=1, X-Forwarded-Host is only trusted if listed here (or derived from PUBLIC_BASE_URL).
# Comma-separated hostnames — required in production behind a reverse proxy unless PUBLIC_BASE_URL is set.
# ALLOWED_PUBLIC_HOSTS=terminal.example.com,www.terminal.example.com

# ── Redis (multi-instance / load balancer) ────────────────────────────────────
# One REDIS_URL enables shared rate limits + guest view dedup (auto backends).
# Local:     REDIS_URL=redis://127.0.0.1:6379
# Password:  REDIS_URL=redis://:your-password@127.0.0.1:6379
# User+pass: REDIS_URL=redis://user:password@redis.example.com:6379
# TLS cloud: REDIS_URL=rediss://default:token@host.upstash.io:6379
# REDIS_URL=redis://127.0.0.1:6379
#
# RATE_LIMIT_BACKEND=auto   # auto | memory | file | redis (production auto → file; redis if REDIS_URL set)
# RATE_LIMIT_SHARED=1       # force file backend for PM2 cluster on ONE host (no Redis needed)

# Guest view dedup backend: auto | file | redis (auto picks redis if REDIS_URL set)
# GUEST_VIEW_DEDUP_BACKEND=auto
# Guest view dedup on store error: 1=fail-open count view (default), 0=fail-closed skip count
# GUEST_VIEW_DEDUP_FAIL_OPEN=1

# ── First-run auth (empty data/auth/users.json only) ─────────────────────────
# Required in production when seeding the default admin + VIP demo accounts.
SEED_ADMIN_PASSWORD=change-me-admin
SEED_VIP_PASSWORD=change-me-vip

# ── Premium vault encryption (production required) ─────────────────────────────
PREMIUM_VAULT_KEY=change-me-long-random-secret

# ── Optional dev ─────────────────────────────────────────────────────────────
# DISABLE_HMR=true

# ── Optional AI Studio / Gemini (meme tools) ─────────────────────────────────
# GEMINI_API_KEY=
# APP_URL=http://localhost:3000